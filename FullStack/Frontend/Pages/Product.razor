@page "/products"
@using Frontend.Client
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Productos</h3>

@if (isLoading)
{
    <p>Cargando...</p>
}
else
{
    @if (error is not null)
    {
        <div class="alert alert-danger">@error</div>
    }

    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/products/frmproduct")'>Crear Producto</button>

    <hr />

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th style="width: 220px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>
                        <button 
                            class="btn btn-sm btn-secondary me-2"
                                @onclick='() => Nav.NavigateTo($"/products/frmproduct/{p.Id}")'>
                            Editar
                        </button>

                        <button class="btn btn-sm btn-danger" @onclick="()=>DeleteAsync(p.Id.Value)" disabled="@isBusy">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<ProductDto> products = null;
    private bool isLoading;
    private string? error = null;
    private bool isBusy;

    private async Task<bool> ConfirmAsync(string message)
        => await JS.InvokeAsync<bool>("confirm", message);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            products = await Api.ProductAsync();
        }
        catch(Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteAsync(int id)
    {
        if (!await ConfirmAsync("Eliminar producto?"))
        {
            return;
        }

        try
        {
            isBusy = true;
            error = null;
            await Api.DeleteproductAsync(id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
